# rct-extractor-v2 — environment template
#
# Copy this file to `.env` and fill in real values before running.
# Never commit your .env (it is gitignored).

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# NCBI E-utilities API key (https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=
